<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="zenith_database"/>
        <include domain="file" path="datastore/settings.preferences_pb"/>

        <exclude domain="database" path="zenith_database-wal"/>
        <exclude domain="database" path="zenith_database-shm"/>
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="zenith_database"/>
        <include domain="file" path="datastore/settings.preferences_pb"/>

        <exclude domain="database" path="zenith_database-wal"/>
        <exclude domain="database" path="zenith_database-shm"/>
    </device-transfer>
</data-extraction-rules>